# AI providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional: enables /api/write/test-models OpenRouter writing model tests.
OPENROUTER_API_KEY=
# Optional: comma-separated ScholarMark user emails or IDs allowed to test Claude Fable 5.
# ANTHROPIC_FABLE_TEST_USER_REFS=you@example.com
# ANTHROPIC_FABLE_MODEL=claude-fable-5
# DeepSeek is enabled by default as the Starter value model. Set both to false to hide it.
ENABLE_DEEPSEEK_WRITING=true
VITE_ENABLE_DEEPSEEK_WRITING=true

# Optional AI credit/cost overrides. Defaults shown are per usage period.
AI_STARTER_CREDITS=250
AI_STARTER_COST_CEILING_CENTS=150
AI_PRO_CREDITS=600
AI_PRO_COST_CEILING_CENTS=450

# Clerk
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Stripe billing
# Uses price lookup keys scholarmark_pro_monthly and scholarmark_max_monthly by default.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional overrides if you do not want to use lookup keys.
# STRIPE_PRO_PRICE_ID=
# STRIPE_MAX_PRICE_ID=
# STRIPE_PORTAL_CONFIGURATION_ID=

# Campaign email
# Used by the Summer Thesis Head Start early access form.
RESEND_API_KEY=
CAMPAIGN_EMAIL_FROM=ScholarMark <hello@scholarmark.ai>
CAMPAIGN_EMAIL_REPLY_TO=support@scholarmark.ai
MARKETING_BASE_URL=https://scholarmark.ai

# Optional Meta ad measurement. Both browser Pixel and server Conversions API
# stay disabled unless META_TRACKING_ENABLED=true and all required values exist.
META_TRACKING_ENABLED=false
VITE_META_TRACKING_ENABLED=false
VITE_META_PIXEL_ID=
META_PIXEL_ID=
META_CONVERSIONS_API_TOKEN=
META_GRAPH_API_VERSION=v25.0
META_ALLOWED_EVENT_ORIGINS=https://scholarmark.ai,https://www.scholarmark.ai,https://app.scholarmark.ai
# Temporary Events Manager test code. Remove after Browser + Server events deduplicate correctly.
META_TEST_EVENT_CODE=

# Production runtime
JWT_SECRET=
APP_BASE_URL=https://app.scholarmark.ai
ALLOWED_ORIGINS=https://app.scholarmark.ai,https://mcp.scholarmark.ai
MCP_RESOURCE_URL=https://mcp.scholarmark.ai
CHROME_EXTENSION_IDS=
# Comma-separated Clerk/ScholarMark user IDs allowed into /admin routes.
ADMIN_USER_IDS=

# Current direct Hetzner app origin, if direct-IP CORS access is needed.
EXTRA_ALLOWED_ORIGINS=http://89.167.10.34
