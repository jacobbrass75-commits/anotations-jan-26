{
  "manifest_version": 3,
  "name": "ScholarMark",
  "version": "1.0.0",
  "description": "Highlight and annotate any webpage. Save to your ScholarMark research projects.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:5001/*",
    "https://app.scholarmark.ai/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5001/*",
        "https://app.scholarmark.ai/*"
      ],
      "js": ["content/content.js"],
      "css": []
    }
  ],
  "options_page": "options/options.html",
  "commands": {
    "save-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save the selected text to ScholarMark"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
